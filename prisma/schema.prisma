generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id         BigInt    @id @default(autoincrement())
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  name               String?
  is_active  Boolean?  @default(true)
  records    Record[]

  @@map("categories")
}

model Department {
  id           BigInt    @id @default(autoincrement())
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  name         String?
  is_active    Boolean?  @default(true)
  account_type String?
  records      Record[]
  balance      Balance?

  @@map("departments")
}

model Member {
  id                 String    @id @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  full_name          String?
  average_tithe      Int?      @default(0)
  highest_tithe      Int?      @default(0)
  lowest_tithe       Int?      @default(0)
  total_tithe        BigInt?   @default(0)
  total_yearly_tithe Int?      @default(0)
  is_active          Boolean?  @default(true)
  records            Record[]

  @@map("members")
}


model Record {
  id                 String    @id @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  member             Member?    @relation(fields: [member_id], references: [id])
  member_id          String? @db.Uuid
  department         Department? @relation(fields: [department_id], references: [id])
  department_id      BigInt?
  category           Category? @relation(fields: [category_id], references: [id])
  category_id        BigInt?
  amount             Int
  income_expense     IncomeExpense  @default(income)
  payment_type       PaymentType    @default(cash)
  description_notes  String?
  date               DateTime
  status             Status?
  deposit_date       DateTime?

  @@map("records")
}

enum IncomeExpense {
  income
  expense
}

enum PaymentType {
  cash
  check
  debitCard
  venmo
}

enum Status {
  deposited
  recorded
}

model Deposit {
  id                 String    @id @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  deposit_date       DateTime
  amount             Int
  notes              String?
  deposit_type       DepositType @default(bank)

  @@map("deposits")
}

enum DepositType {
  bank
  venmo
}

model Balance {
  id                 String    @id @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  department         Department @relation(fields: [department_id], references: [id])
  department_id      BigInt @unique
  balance            Int
  previous_balance   Int?
  current_year       String? @db.VarChar(4)
  previous_year      String? @db.VarChar(4)

  @@map("balances")
}

model User {
  id                 String    @id @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  username           String @unique
  name               String
  email              String
  preferences        Preference?
  profile_image      Bytes?

  @@map("users")
}

model Preference {
  id                 BigInt     @id @default(autoincrement())
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  last_modified      DateTime   @default(now()) @db.Timestamptz(6)
  user               User       @relation(fields: [user_id], references: [id])
  user_id            String     @db.Uuid @unique 
  language           Language   @default(english)
  theme              String?    @db.VarChar(30)
  quick_links        Json?

  @@map("preferences")
}

enum Language {
  english
  spanish
}